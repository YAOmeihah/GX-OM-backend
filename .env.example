#==========================================================================
# 应用基础配置
#==========================================================================

# 应用名称 - 显示在邮件、通知等位置
APP_NAME="欠款管理系统"

# 运行环境: local(本地开发), staging(测试), production(生产)
APP_ENV=local

# 应用密钥 - 用于加密，首次部署需运行: php artisan key:generate
APP_KEY=

# 调试模式 - 生产环境必须设为 false
APP_DEBUG=true

# 时区设置
APP_TIMEZONE=Asia/Shanghai

# 应用URL - 用于生成完整链接
APP_URL=http://localhost

# 语言设置
APP_LOCALE=zh_CN
APP_FALLBACK_LOCALE=zh_CN

#==========================================================================
# 数据库配置
#==========================================================================

# 数据库驱动: mysql, pgsql, sqlite, sqlsrv
DB_CONNECTION=mysql

# 数据库连接信息
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=qkdemo
DB_USERNAME=root
DB_PASSWORD=root

#==========================================================================
# 缓存与会话配置
#==========================================================================

# 缓存驱动: file, database, redis, memcached
CACHE_STORE=database

# 会话驱动: file, cookie, database, redis
SESSION_DRIVER=database

# 会话有效期（分钟）
SESSION_LIFETIME=120

# 队列驱动: sync, database, redis, beanstalkd, sqs
QUEUE_CONNECTION=database

#==========================================================================
# 日志配置
#==========================================================================

# 日志通道: single, daily, slack, syslog, errorlog, stack
LOG_CHANNEL=stack
LOG_STACK=single

# 日志级别: debug, info, notice, warning, error, critical, alert, emergency
LOG_LEVEL=debug

#==========================================================================
# S3兼容对象存储配置
# 支持: AWS S3, 阿里云OSS, 腾讯云COS, 缤纷云, MinIO 等S3协议存储
#==========================================================================

# 访问密钥
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key

# 存储区域（根据服务商设置，如: cn-east-1, us-east-1, ap-southeast-1）
S3_REGION=cn-east-1

# 存储桶名称
S3_BUCKET=your_bucket_name

# 服务端点URL（不同服务商不同）
# 缤纷云: https://s3.bitiful.net
# 阿里云OSS: https://oss-cn-hangzhou.aliyuncs.com
# 腾讯云COS: https://cos.ap-guangzhou.myqcloud.com
# MinIO: http://localhost:9000
S3_ENDPOINT=https://s3.bitiful.net

# 公开访问URL（可选，用于生成公开链接）
S3_URL=

# 是否使用路径风格端点（MinIO等自建服务通常需要设为true）
S3_USE_PATH_STYLE=false

# SSL证书验证（自签名证书的服务可设为false）
S3_SSL_VERIFY=false

#==========================================================================
# 附件上传配置
#==========================================================================

# 附件存储磁盘（对应filesystems.php中的disk名称）
ATTACHMENT_DISK=s3-compat

# 最大文件大小（字节，默认10MB）
ATTACHMENT_MAX_SIZE=10485760

# 预签名URL有效期（分钟）
ATTACHMENT_PRESIGNED_EXPIRES=20

#==========================================================================
# 后端系统更新配置
#==========================================================================

# GitHub Release 仓库
SYSTEM_UPDATE_GITHUB_OWNER=YAOmeihah
SYSTEM_UPDATE_GITHUB_REPO=GX-OM-backend

# 可选：GitHub Personal Access Token，用于提高 Release API 限额
SYSTEM_UPDATE_GITHUB_TOKEN=

# 可选：公开 Release 更新包下载加速地址
SYSTEM_UPDATE_GITHUB_DOWNLOAD_BASE_URL=https://ghfast.top/https://github.com

#==========================================================================
# 审计日志配置
#==========================================================================

# 是否启用审计日志
AUDIT_ENABLED=true

# 审计日志保留天数
AUDIT_RETENTION_DAYS=90

# 是否记录查看操作（会产生大量日志）
AUDIT_LOG_VIEWS=false

#==========================================================================
# 支付/还款配置
#==========================================================================

# 单次最大优惠减免金额
PAYMENT_MAX_DISCOUNT_AMOUNT=1000

# 每日优惠减免限额
PAYMENT_DAILY_DISCOUNT_LIMIT=5000

# 自动优惠减免配置
PAYMENT_AUTO_DISCOUNT_ENABLED=true
PAYMENT_AUTO_DISCOUNT_MAX_AMOUNT=100
PAYMENT_AUTO_DISCOUNT_THRESHOLD=10

#==========================================================================
# 安全配置
#==========================================================================

# 密码加密轮数（越高越安全但越慢）
BCRYPT_ROUNDS=12

#==========================================================================
# 微信小程序配置
#==========================================================================

# 小程序 AppID（微信公众平台 → 开发管理 → 开发设置）
WECHAT_MINI_APP_ID=
# 小程序 AppSecret
WECHAT_MINI_APP_SECRET=
